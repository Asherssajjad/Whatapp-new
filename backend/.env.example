# ─── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/whatsapp_bot"

# ─── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY="sk-proj-..."
OPENAI_MODEL="gpt-4o"                          # gpt-4o / gpt-4o-mini / gpt-4-turbo
OPENAI_EMBEDDING_MODEL="text-embedding-3-small"
OPENAI_WHISPER_MODEL="whisper-1"
OPENAI_MAX_TOKENS="1000"
OPENAI_TEMPERATURE="0.3"

# ─── WhatsApp Meta Cloud API ───────────────────────────────────────────────────
VERIFY_TOKEN="your_webhook_verify_token_here"

# ─── JWT Auth ──────────────────────────────────────────────────────────────────
JWT_SECRET="your_super_secret_jwt_key_here"
JWT_REFRESH_SECRET="your_super_secret_refresh_key_here"
JWT_EXPIRES_IN="7d"

# ─── Server ────────────────────────────────────────────────────────────────────
PORT="5000"
NODE_ENV="development"
CORS_ORIGINS="http://localhost:3000"

# ─── Super Admin (auto-created on first run) ───────────────────────────────────
ADMIN_EMAIL="admin@yourcompany.com"
ADMIN_PASSWORD="Admin@2026!"
ADMIN_NAME="Super Admin"
ADMIN_WHATSAPP="+923001234567"

# ─── Seed: Primary Organization (optional – auto-creates on first run) ─────────
SEED_ORG_NAME="My Business"
SEED_PHONE_NUMBER_ID="your_phone_number_id"
SEED_ACCESS_TOKEN="your_whatsapp_access_token"
SEED_WABA_ID="your_waba_id"
SEED_BUSINESS_TYPE="SERVICES"           # SERVICES / ECOMMERCE / GENERAL
SEED_SPECIAL_INSTRUCTIONS="Always respond in Roman Urdu and English."
